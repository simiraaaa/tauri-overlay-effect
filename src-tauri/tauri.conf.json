{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Overlay Effect",
  "version": "0.1.0",
  "identifier": "io.github.simiraaaa.overlay-effect",
  "build": {
    "beforeDevCommand": "npm run dev:svelte",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../build"
  },
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' http://localhost:5173 ws://localhost:5173; font-src 'self'; media-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self';"
    },
    "windows": [
      {
        "label": "main",
        "title": "Overlay Effect",
        "width": 800,
        "height": 600,
        "resizable": false,
        "fullscreen": true,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "shadow": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": ["../images/icon.png"]
  }
}
