{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Overlay Effect",
  "version": "0.1.0",
  "identifier": "io.github.simiraaaa.overlay-effect",
  "build": {
    "beforeDevCommand": "npm run dev:svelte",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../build"
  },
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Overlay Effect",
        "width": 800,
        "height": 600,
        "resizable": false,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "shadow": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": ["../images/icon.png"]
  }
}
